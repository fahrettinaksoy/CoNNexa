{
  "name": "connexa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Connexa — SSH / RDP / VNC / Telnet Uzak Erişim Yöneticisi (Tauri v2 + Vue + Vuetify)",
  "author": "Fahrettin Aksoy",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,vue}": "eslint --cache --fix",
    "*.{ts,js,vue,json,md,yml,yaml,scss,css,html}": "prettier --write"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@novnc/novnc": "^1.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@vueuse/core": "^14.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "ironrdp-wasm": "^1.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.2.0",
    "vuetify": "^4.1.5"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.19.0",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^2.1.8",
    "vue-tsc": "^3.3.7"
  }
}
